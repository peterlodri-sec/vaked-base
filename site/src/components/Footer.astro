---
// Custom footer: render Starlight's default footer (pagination, last-updated,
// edit link) and append the Vaked mantra beneath it.
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default><slot /></Default>

<footer class="vaked-mantra">
  <p>
    Vaked declares · Nix materializes · OTP supervises · Zig enforces · eBPF
    testifies · CrabCC indexes · Surfaces reveal
  </p>
</footer>

<style>
  .vaked-mantra {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--sl-color-hairline);
    text-align: center;
  }
  .vaked-mantra p {
    margin: 0;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    letter-spacing: 0.02em;
  }
</style>
