{
  "mcpServers": {
    "github": {
      "command": "gh",
      "args": ["mcp", "--json"],
      "enabled": true,
      "description": "GitHub PR/issue management, code search, repo operations"
    },
    "workspace-fs": {
      "command": "codewhale",
      "args": ["mcp", "workspace-fs", "--path", "/home/dev/vaked-dev"],
      "enabled": true,
      "description": "Sandboxed filesystem access to vaked-dev workspace"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/context7-mcp-server"],
      "enabled": false,
      "description": "Library docs for Nix/Zig/eBPF/MLIR — disabled by default (no Playwright)"
    }
  },
  "llm": {
    "provider": "openai",
    "baseUrl": "http://dev-cx53:4000/v1",
    "apiKey": "",
    "defaultModel": "cloud/deepseek-v4-flash",
    "models": {
      "cloud/deepseek-v4-flash": {"type": "chat", "speed": "fast"},
      "cloud/claude-opus-4": {"type": "chat", "speed": "slow"},
      "remote/deepseek-coder": {"type": "chat", "speed": "fast"},
      "local/qwen2.5-coder": {"type": "chat", "speed": "fast"},
      "z-ai/glm-5": {"type": "chat", "speed": "medium", "note": "GLM-5.2 — Zhipu flagship, strong reasoning + bilingual"},
      "z-ai/glm-4.5-air": {"type": "chat", "speed": "fast", "note": "GLM-4.5-Air — lighter companion, quick tasks"}
    }
  },
  "agent": {
    "name": "whale",
    "maxTurns": 50,
    "maxTokens": 8192,
    "temperature": 0.3
  }
}
