{
  "name": "@vaked/openrouter-ts",
  "version": "0.1.0",
  "private": true,
  "description": "OpenRouter Agent SDK toolkit for Vaked — replaces hand-rolled Python HTTP with type-safe agent primitives",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./deliberate": "./dist/deliberate.js"
  },
  "bin": {
    "orcli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openrouter/agent": "^0.7.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
