{
  "name": "@vaked/openrouter-ts",
  "version": "0.2.0",
  "private": true,
  "description": "OpenRouter Agent SDK toolkit for Vaked \u2014 type-safe agent primitives with first-class Context7 integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./deliberate": "./dist/deliberate.js",
    "./context7": "./dist/context7.js"
  },
  "bin": {
    "orcli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/ *.tsbuildinfo",
    "start": "node --enable-source-maps dist/cli.js",
    "orcli": "node --turbo-fast-api-calls --enable-source-maps --expose-gc dist/cli.js",
    "orcli:ask": "node --turbo-fast-api-calls --max-old-space-size=512 dist/cli.js --model deepseek",
    "orcli:code": "node --turbo-fast-api-calls --max-old-space-size=8192 dist/cli.js --model claude",
    "orcli:review": "node --turbo-fast-api-calls --max-old-space-size=4096 dist/cli.js --model claude --max-tokens 600",
    "orcli:deliberate": "node --turbo-fast-api-calls --max-old-space-size=8192 dist/cli.js --deliberate",
    "orcli:bun": "bun run --silent dist/cli.js",
    "orcli:bun:smol": "bun run --smol --silent dist/cli.js",
    "orcli:bun:code": "MIMALLOC_PAGE_RESET=1 MIMALLOC_PURGE_DELAY=10000 bun run --silent dist/cli.js --model claude",
    "orcli:bun:deliberate": "MIMALLOC_LARGE_OS_PAGES=1 bun run --silent dist/cli.js --deliberate",
    "orcli:deno": "deno run --allow-env --allow-net --allow-read --allow-write=$HOME/.orcli_budget dist/cli.js",
    "bench": "node --expose-gc --max-old-space-size=4096 --turbo-fast-api-calls --enable-source-maps --max-semi-space-size=16 dist/cli.js",
    "bench:heap": "node --expose-gc --max-old-space-size=4096 --heap-prof --cpu-prof --enable-source-maps dist/cli.js",
    "bench:bun": "MIMALLOC_SHOW_STATS=1 bun run --smol dist/cli.js",
    "bench:deno": "deno run --allow-all --v8-flags=--expose-gc dist/cli.js",
    "profile:cpu": "node --cpu-prof --cpu-prof-interval=1000 --cpu-prof-dir=.profiles dist/cli.js",
    "profile:heap": "node --heap-prof --heap-prof-interval=1000 --heap-prof-dir=.profiles dist/cli.js",
    "lint": "tsc --noEmit",
    "lint:deno": "deno check src/**/*.ts",
    "prebuild": "npm run clean",
    "postbuild": "chmod +x dist/cli.js",
    "prepublishOnly": "npm run build && npm run typecheck",
    "audit": "npm audit --audit-level=high",
    "audit:all": "npm audit",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated",
    "sbom": "npm sbom --sbom-format=cyclonedx",
    "build:oxc": "oxc-transform src/ --out-dir dist/ --source-map",
    "lint:oxc": "oxlint src/",
    "fmt:oxc": "oxc format src/",
    "check:oxc": "oxlint src/ && oxc-transform src/ --out-dir dist/ --no-emit"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@openrouter/agent": "^0.7.2",
    "langfuse": "^3.38.20",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "oxc-transform": "^0.56.0",
    "oxlint": "^0.15.0"
  },
  "overrides": {
    "protobufjs": ">=7.4.0",
    "json5": ">=2.2.3",
    "minimist": ">=1.2.8",
    "tough-cookie": ">=4.1.4",
    "@babel/traverse": ">=7.26.0",
    "semver": ">=7.6.0",
    "word-wrap": ">=1.2.5",
    "http-cache-semantics": ">=4.1.1",
    "debug": ">=4.3.4",
    "node-fetch": ">=2.7.0",
    "@xmldom/xmldom": ">=0.8.10",
    "vite": ">=5.4.0",
    "webpack-dev-middleware": ">=7.1.0",
    "jsonwebtoken": ">=9.0.2",
    "jose": ">=5.0.0",
    "cross-spawn": ">=7.0.6",
    "micromatch": ">=4.0.8",
    "braces": ">=3.0.3",
    "glob": ">=10.4.0",
    "glob-parent": ">=6.0.2",
    "path-to-regexp": ">=8.0.0"
  }
}
