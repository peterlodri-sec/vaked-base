{
  "name": "@vaked/openrouter-ts",
  "version": "0.2.0",
  "private": true,
  "description": "OpenRouter Agent SDK toolkit for Vaked — type-safe agent primitives with first-class Context7 integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./deliberate": "./dist/deliberate.js",
    "./context7": "./dist/context7.js"
  },
  "bin": {
    "orcli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/ *.tsbuildinfo",
    "start": "node --enable-source-maps dist/cli.js",
    "orcli": "node --enable-source-maps dist/cli.js",
    "orcli:ask": "node --enable-source-maps dist/cli.js --model deepseek",
    "orcli:code": "node --enable-source-maps dist/cli.js --model claude",
    "orcli:review": "node --enable-source-maps dist/cli.js --model claude",
    "orcli:deliberate": "node --enable-source-maps dist/cli.js --deliberate",
    "orcli:bun": "bun run dist/cli.js",
    "orcli:deno": "deno run --allow-env --allow-net --allow-read dist/cli.js",
    "bench": "node --expose-gc --max-old-space-size=4096 --enable-source-maps dist/cli.js",
    "bench:bun": "bun run --smol dist/cli.js",
    "prebuild": "npm run clean",
    "postbuild": "chmod +x dist/cli.js",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@openrouter/agent": "^0.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  }
}
