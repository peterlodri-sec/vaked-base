# ═══════════════════════════════════════════════════════════════
# npm security configuration for @vaked/openrouter-ts
# ═══════════════════════════════════════════════════════════════

# Audit on install — fail on known vulns
audit=true
audit-level=high

# Strict lockfile — prevent drift
package-lock=true
lockfile-version=3
engine-strict=true

# Funding noise off
fund=false

# Ignore scripts from untrusted packages (defense against supply-chain)
ignore-scripts=false

# Prefer offline cache for reproducibility
prefer-offline=false

# Provenance verification (npm ≥9)
# verify-attestations=true
