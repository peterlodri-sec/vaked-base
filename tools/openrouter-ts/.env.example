# ═══════════════════════════════════════════════════════════════
# @vaked/openrouter-ts — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Optional: Context7 (live library docs) ────────────────────
CONTEXT7_API_KEY=ctx7sk-...

# ── Optional: Langfuse tracing ────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Optional: Swarm telemetry ─────────────────────────────────
SWARM_TELEMETRY=false
SWARM_INGEST_URL=https://api.vaked-swarm.io/ingest/trajectory

# ── Budget tracking ───────────────────────────────────────────
# Budget file location (default: ~/.orcli_budget)
ORCLI_BUDGET_FILE=~/.orcli_budget
# Default budget cap in USD (default: 6.00)
ORCLI_BUDGET_CAP=6.00

# ── Caching ───────────────────────────────────────────────────
# SHA256 cache for file contents (default: ~/.deepseek_cache.json)
DEEPSEEK_CACHE_FILE=~/.deepseek_cache.json
# Reference tracking file (default: ~/.deepseek_refs.txt)
DEEPSEEK_REFS_FILE=~/.deepseek_refs.txt

# ── HTTP tuning ───────────────────────────────────────────────
# Connection pool size (default: 256)
HTTP_MAX_SOCKETS=256
# Keep-alive timeout in ms (default: 5000)
HTTP_KEEPALIVE_TIMEOUT=5000
# DNS cache TTL in seconds (default: 300)
DNS_CACHE_TTL=300
# Request timeout in ms (default: 120000)
HTTP_TIMEOUT=120000

# ── Concurrency ───────────────────────────────────────────────
# Deliberation panel parallelism (default: 8)
DELIBERATE_CONCURRENCY=8
# Deliberation budget cap in USD (default: 10.00)
DELIBERATE_BUDGET_CAP=10.00

# ── Defaults ──────────────────────────────────────────────────
# Default model (alias from MODELS map)
ORCLI_DEFAULT_MODEL=deepseek
# Default system prompt
ORCLI_DEFAULT_SYSTEM="You are a helpful assistant."
# Default max output tokens
ORCLI_DEFAULT_MAX_TOKENS=1000

# ── Langfuse Observability (GitHub CI Environment `ci`) ──────────────
# Guarded — agent no-ops cleanly when unset. Never blocks.
# Secrets: Settings → Environments → ci → Secrets
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST (optional, default: https://cloud.langfuse.com)
LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_BASE_URL (legacy alias for LANGFUSE_HOST)
VAST_API_KEY=...
VAULT_TOKEN=...
CONTEXT7_ENDPOINT=https://context7.com/api/v2  # changeable — use your own or Vaked Docs
CUBE_API_SECRET=...   # Cube semantic layer auth
CUBE_API_URL=http://localhost:4000/cubejs-api/v1
MEMORYD_URL=http://localhost:8420  # Vaked memory plane
MILVUS_URL=http://localhost:19530/api/v1
