{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["es2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "imports": {
    "@openrouter/agent": "npm:@openrouter/agent@^0.7.2",
    "zod": "npm:zod@^4.4.3"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": true,
    "semiColons": true
  },
  "tasks": {
    "build": "deno run --allow-all npm:typescript/tsc",
    "typecheck": "deno run --allow-all npm:typescript/tsc --noEmit",
    "orcli": "deno run --allow-env --allow-net --allow-read --allow-write=$HOME/.orcli_budget dist/cli.js"
  }
}
