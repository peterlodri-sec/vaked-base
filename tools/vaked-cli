# ── Async shell ────────────────────────────────────────────────────────
async def _sh(*args, **kwargs) -> subprocess.CompletedProcess:
    """Async shell wrapper. All remote commands go through this."""
    proc = await asyncio.create_subprocess_exec(
        *args,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
        **kwargs,
    )
    stdout, stderr = await proc.communicate()
    return subprocess.CompletedProcess(args, proc.returncode, stdout.decode(), stderr.decode())


async def _ssh(cmd: str, sudo: bool = False, timeout: float = 15.0) -> tuple[int, str]:
    """Execute on dev-cx53. Returns (exit_code, stdout)."""
    try:
        args = ["ssh", TARGET]
        if sudo:
            args.append("sudo")
        args.extend(["bash", "-c", cmd])
        result = await asyncio.wait_for(_sh(*args), timeout=timeout)
        return result.returncode, result.stdout.strip()
    except asyncio.TimeoutError:
        return 124, ""
    except Exception as e:
        return 1, str(e)


async def _scp(local: str, remote: str) -> bool:
    """SCP a file to dev-cx53."""
    try:
        result = await asyncio.wait_for(
            _sh("scp", local, f"{TARGET}:{remote}"),
            timeout=30.0,
        )
        return result.returncode == 0
    except Exception:
        return False


# ── Deploy ─────────────────────────────────────────────────────────────
async def deploy_website() -> list[DeployResult]:
    """Deploy all static website files. Returns results."""
    results: list[DeployResult] = []
    
    async def _deploy_one(local: str, remote: str) -> DeployResult:
        if not os.path.isfile(local):
            return DeployResult(local, remote, 0, False)
        
        remote_dir = os.path.dirname(remote)
        await _ssh(f"sudo mkdir -p {remote_dir}", sudo=False)
        
        with open(local, "rb") as f:
            content = f.read()
        
        proc = await asyncio.create_subprocess_exec(
            "ssh", TARGET, f"sudo tee {remote} > /dev/null",
            stdin=asyncio.subprocess.PIPE,
            stdout=asyncio.subprocess.DEVNULL,
            stderr=asyncio.subprocess.DEVNULL,
        )
        await proc.communicate(input=content)
        
        _, size_str = await _ssh(f"wc -c < {remote}")
        size = int(size_str) if size_str.isdigit() else 0
        ok = size > 0
        print(f"{'✅' if ok else '❌'} {os.path.basename(local):30s} → {size}B")
        return DeployResult(local, remote, size, ok)
    
    tasks = [_deploy_one(l, r) for l, r in SITE_MAP.items()]
    results = await asyncio.gather(*tasks)
    
    ok = sum(1 for r in results if r.ok)
    print(f"\n{ok}/{len(results)} deployed")
    return results


async def deploy_file(local: str, remote: Optional[str] = None) -> DeployResult:
    """Deploy a single file."""
    if remote is None:
        base = os.path.basename(local).replace(".html", "")
        remote = f"/var/www/{base}/index.html"
    
    remote_dir = os.path.dirname(remote)
    await _ssh(f"sudo mkdir -p {remote_dir}")
    
    if not os.path.isfile(local):
        print(f"❌ {local} — not found")
        return DeployResult(local, remote, 0, False)
    
    with open(local, "rb") as f:
        content = f.read()
    
    proc = await asyncio.create_subprocess_exec(
        "ssh", TARGET, f"sudo tee {remote} > /dev/null",
        stdin=asyncio.subprocess.PIPE,
        stdout=asyncio.subprocess.DEVNULL,
        stderr=asyncio.subprocess.DEVNULL,
    )
    await proc.communicate(input=content)
    
    _, size_str = await _ssh(f"wc -c < {remote}")
    size = int(size_str) if size_str.isdigit() else 0
    ok = size > 0
    print(f"{'✅' if ok else '❌'} {local} → {remote} ({size}B)")
    return DeployResult(local, remote, size, ok)


async def deploy_route(path: str, dirname: str) -> bool:
    """Add route to gateway source, build, deploy, test."""
    # 1. Edit source
    route_line = f'    .{{ .path = "{path}", .content_type = "text/html", .file_path = "/var/www/{dirname}/index.html", .inline_content = null }},'
    gw_src = "gateway/gw_v3.zig"
    
    with open(gw_src) as f:
        src = f.read()
    
    if path in src:
        print(f"⚠️  Route {path} already in source")
    
    src = src.replace(
        '    .{ .path = "/mesh.json"',
        f'{route_line}\n    .{{ .path = "/mesh.json"'
    )
    with open(gw_src, "w") as f:
        f.write(src)
    
    # 2. Build
    if not await _scp(gw_src, "/tmp/gw_route.zig"):
        print("❌ SCP failed")
        return False
    
    code, out = await _ssh(
        "cd /tmp && zig build-exe gw_route.zig -O ReleaseFast -fstrip --name vaked-gw-new 2>&1",
        timeout=120.0,
    )
    if code != 0:
        print(f"❌ Build failed: {out[-200:]}")
        return False
    
    # 3. Deploy + restart
    await _ssh(
        "systemctl --user stop constellation-gateway; fuser -k 8081/tcp 2>/dev/null; sleep 1; "
        "sudo cp -f /tmp/vaked-gw-new /opt/vaked/vaked-gateway; "
        "systemctl --user start constellation-gateway",
        timeout=15.0,
    )
    await asyncio.sleep(2)
    
    # 4. Test
    result = await asyncio.create_subprocess_exec(
        "curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
        f"https://constellation.vaked.dev{path}",
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.DEVNULL,
    )
    stdout, _ = await result.communicate()
    code = stdout.decode().strip()
    ok = code == "200"
    print(f"{'✅' if ok else '❌'} {path} → {code}")
    return ok


# ── Build ──────────────────────────────────────────────────────────────
async def build_target(name: str) -> BuildResult:
    """Build a Zig binary and deploy it."""
    zig_map = {
        "gw": "gateway/gw_v3.zig",
        "gateway": "gateway/gw_v3.zig",
        "monologue": "tools/monologue/monologue.zig",
        "chat": "chat-gateway/src/main.zig",
    }
    src = zig_map.get(name, name)
    binary = f"vaked-{name}"
    
    if not await _scp(src, f"/tmp/build_{name}.zig"):
        return BuildResult(name, "0", False, "SCP failed")
    
    code, out = await _ssh(
        f"cd /tmp && zig build-exe build_{name}.zig -O ReleaseFast -fstrip --name {binary} 2>&1",
        timeout=120.0,
    )
    
    if code != 0:
        return BuildResult(name, "0", False, out[-300:])
    
    _, size = await _ssh(f"ls -lh /tmp/{binary} | awk '{{print $5}}'")
    print(f"✅ {name} · {size}")
    return BuildResult(name, size, True)


# ── Status ─────────────────────────────────────────────────────────────
async def show_status() -> StatusResult:
    """Full system health check."""
    gw_code, gw_status = await _ssh("systemctl --user is-active constellation-gateway 2>/dev/null || echo down")
    tun_code, tun_pid = await _ssh("pgrep -f cloudflared | head -1 || echo down")
    
    print(f"Gateway:  {gw_status}")
    print(f"Tunnel:   {'running' if tun_pid.isdigit() else 'down'}")
    
    endpoints: dict[str, int] = {}
    for ep in ["/", "/health", "/wisdom", "/radio", "/nav", "/donate", "/chat", "/mesh.json"]:
        result = await asyncio.create_subprocess_exec(
            "curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
            f"https://constellation.vaked.dev{ep}",
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.DEVNULL,
        )
        stdout, _ = await asyncio.wait_for(result.communicate(), timeout=10.0)
        code = int(stdout.decode().strip() or "0")
        endpoints[ep] = code
        print(f"  {code}  {ep}")
    
    _, ledger_str = await _ssh("sudo wc -l < /var/lib/private/meta-ralphd/oculus.jsonl 2>/dev/null || echo ?")
    _, grave_str = await _ssh("wc -l < /var/log/vaked/graveyard.log 2>/dev/null || echo ?")
    ledger = int(ledger_str) if ledger_str.isdigit() else 0
    grave = int(grave_str) if grave_str.isdigit() else 0
    
    print(f"\nLedger: {ledger} · Graveyard: {grave} · Genesis: {GENESIS_SEAL[:8]}")
    return StatusResult(gw_status, "running" if tun_pid.isdigit() else "down", endpoints, ledger, grave)


# ── CLI ────────────────────────────────────────────────────────────────
async def _main_async() -> int:
    """Async entry point."""
    if len(sys.argv) < 2:
        print(__doc__)
        return 0
    
    cmd, *args = sys.argv[1], sys.argv[2:]
    
    try:
        if cmd == "deploy":
            sub = args[0] if args else "website"
            if sub == "website":
                await deploy_website()
            elif sub == "file":
                await deploy_file(args[1], args[2] if len(args) > 2 else None)
            elif sub == "route":
                await deploy_route(args[1], args[2])
            else:
                print(f"Unknown deploy target: {sub}")
                return 1
        
        elif cmd == "build":
            result = await build_target(args[0] if args else "gw")
            if not result.ok:
                print(f"Build error: {result.error[:200]}")
                return 1
        
        elif cmd == "run":
            if not args:
                print("Usage: vaked-cli run <script.py|--shell cmd>")
                return 1
            if args[0] == "--shell":
                code, out = await _ssh(args[1], timeout=60.0)
                print(out)
            else:
                # File-based: scp + execute
                script = args[0]
                if os.path.isfile(script):
                    await _scp(script, "/tmp/vcli_run.py")
                    code, out = await _ssh("python3 /tmp/vcli_run.py", timeout=60.0)
                    print(out)
                    await _ssh("rm -f /tmp/vcli_run.py")
                else:
                    print(f"File not found: {script}")
                    return 1
        
        elif cmd == "status":
            await show_status()
        
        elif cmd == "routes":
            with open("gateway/gw_v3.zig") as f:
                import re
                for r in re.findall(r'\.path = "([^"]+)"', f.read()):
                    print(f"  {r}")
        
        elif cmd == "test":
            if not args:
                print("Usage: vaked-cli test <path>")
                return 1
            result = await asyncio.create_subprocess_exec(
                "curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
                f"https://constellation.vaked.dev{args[0]}",
                stdout=asyncio.subprocess.PIPE,
            )
            stdout, _ = await result.communicate()
            print(f"{stdout.decode().strip()}  {args[0]}")
        
        elif cmd == "ledger":
            n = int(args[0]) if args else 5
            _, out = await _ssh(f"sudo tail -{n} /var/lib/private/meta-ralphd/oculus.jsonl", timeout=10.0)
            for line in out.split("\n"):
                if not line.strip():
                    continue
                try:
                    e = json.loads(line)
                    k = e.get("payload", {}).get("kind", "?")
                    h = e.get("hash", "")[:12]
                    print(f"  {e.get('seq', '?'):3d}  {k:25s}  {h}")
                except Exception:
                    pass
        
        else:
            print(f"Unknown command: {cmd}")
            return 1
    
    except KeyboardInterrupt:
        print("\n⚠️  Interrupted — exiting gracefully")
        return 130
    except Exception as e:
        print(f"❌ {e}")
        return 1
    
    return 0


def _handle_signal(signum: int, frame) -> None:
    """Graceful exit on signal."""
    print(f"\n⚠️  Signal {signum} received — exiting")
    sys.exit(128 + signum)


def main() -> int:
    """Sync entry point with signal handling."""
    signal.signal(signal.SIGINT, _handle_signal)
    signal.signal(signal.SIGTERM, _handle_signal)
    return asyncio.run(_main_async())


if __name__ == "__main__":
    sys.exit(main())
