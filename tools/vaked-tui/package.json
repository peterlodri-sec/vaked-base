{
  "name": "@vaked/tui",
  "version": "0.1.0",
  "private": true,
  "description": "Vaked TUI \u2014 cross-platform, battle-tested terminal agent. Zero GUI deps.",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "vaked": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main.js",
    "ci": "node dist/main.js --ci",
    "oneshot": "node dist/main.js --oneshot",
    "build:oxc": "oxc-transform src/ --out-dir dist/",
    "lint:oxc": "oxlint src/",
    "fmt:oxc": "oxc format src/"
  },
  "dependencies": {
    "@vaked/openrouter-ts": "file:../openrouter-ts"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.9.3",
    "oxc-transform": "^0.56.0",
    "oxlint": "^0.15.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
