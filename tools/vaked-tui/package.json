{
  "name": "@vaked/tui",
  "version": "0.1.0",
  "private": true,
  "description": "Vaked TUI — cross-platform, battle-tested terminal agent. Zero GUI deps.",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "vaked": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main.js",
    "ci": "node dist/main.js --ci",
    "oneshot": "node dist/main.js --oneshot"
  },
  "dependencies": {
    "@vaked/openrouter-ts": "file:../openrouter-ts"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
