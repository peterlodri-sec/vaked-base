# langfuse.crabcc.app — server-side env vars for the Langfuse web + worker containers.
# Copy to .env and fill in. DO NOT commit the real .env.

# ── LLM-as-a-Judge provider defaults ────────────────────────────────────────
# Pre-fill the "Model Adapter" and "Base URL" fields in the UI when operators
# add an LLM connection under Project Settings → LLM API Keys.
# OpenRouter is OpenAI-compatible; use the OpenAI adapter with its base URL.
LANGFUSE_UI_DEFAULT_MODEL_ADAPTER=OpenAI
LANGFUSE_UI_DEFAULT_BASE_URL_OPENAI=https://openrouter.ai/api/v1

# The actual OpenRouter API key is entered per-project in the Langfuse UI
# (Project Settings → LLM API Keys → + Add). It is stored in the Langfuse DB,
# not in this file. Recommended model for evals: google/gemma-3-12b-it (cheap)
# or deepseek/deepseek-v4-flash (strong on code review traces).

# ── Auth / core ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://langfuse.crabcc.app
NEXTAUTH_SECRET=change-me-random-32-char-string
SALT=change-me-random-32-char-string

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://langfuse:change-me@db:5432/langfuse

# ── Bootstrap org/project (first-run only; idempotent after that) ────────────
# LANGFUSE_INIT_ORG_ID=
# LANGFUSE_INIT_PROJECT_ID=
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-...
# LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-...
