# llmproxy.crabcc.app — copy to .env and fill in. DO NOT commit the real .env.

# The ONE real upstream key (OpenRouter). Lives only on this host.
OPENROUTER_API_KEY=sk-or-...

# LiteLLM admin/master key — mints virtual keys; never leaves the host.
LITELLM_MASTER_KEY=sk-llmproxy-master-change-me
# Salt for encrypting stored provider keys (generate a random 32+ char string).
LITELLM_SALT_KEY=change-me-random-salt

# Postgres password (keys/budgets/spend store).
POSTGRES_PASSWORD=change-me

# Gateway-level Langfuse tracing (same project the CI agents trace to).
LANGFUSE_HOST=https://langfuse.crabcc.app
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Optional: Cloudflare Tunnel token (uncomment the cloudflared service to use).
# CLOUDFLARE_TUNNEL_TOKEN=
