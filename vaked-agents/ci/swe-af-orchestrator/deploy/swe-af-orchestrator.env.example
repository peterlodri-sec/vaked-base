# /etc/swe-af/orchestrator.env  (chmod 600 — contains tokens)
# Copy to /etc/swe-af/orchestrator.env and fill the tokens.

NATS_URL=nats://100.73.72.35:4222
# NATS_CREDS=/etc/swe-af/worker.creds        # once the JWT cluster is live
SWE_AF_STREAM=SWE_AF_TASKS
SWE_AF_SUBJECT=swe.af.tasks
SWE_AF_CONSUMER=swe-af-workers
SWE_AF_STATUS_PREFIX=swe.af.status

SWE_AF_POOL=6
SWE_AF_SCRATCH=/var/lib/swe-af/scratch
SWE_AF_MIN_FREE_GB=10
SWE_AF_SCRATCH_CAP_GB=20

SWE_AF_BIN=/usr/local/bin/vaked-swe-af
OPENROUTER_BASE_URL=https://nixai-base.tail2870dc.ts.net/aperture/v1
SWE_AF_API_KEY=tailscale-identity
SWE_AF_PLAN_MODEL=deepseek/deepseek-v4-flash
SWE_AF_CODE_MODEL=openai/gpt-5.3-codex

# GH_TOKEN: read scope, for `gh issue view` inside vaked-swe-af (POLA: no write).
# GH_TOKEN=
# SWE_AF_GH_WRITE_TOKEN: write scope, used ONLY for the broker `gh pr create`.
# SWE_AF_GH_WRITE_TOKEN=
