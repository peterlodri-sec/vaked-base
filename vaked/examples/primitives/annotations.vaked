# Minimal v0.2 example — annotation syntax
# Demonstrates: @name and @name(arg) decorators on declarations.

@experimental
budget expBudget {
  cpu    = "1 core"
  memory = "2G"
}

@deprecated("use expBudget instead")
budget legacyBudget {
  cpu = "512m"
}

@stable
host controlPlane {
  hostname = "cp-01"
}
