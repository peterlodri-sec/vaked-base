# Minimal v0.2 example — declaration kinds with no built-in schema
# Demonstrates: host, budget, runclass, ebpf, observability kinds.

host productionNode {
  hostname = "vaked-host-01"
  system   = "x86_64-linux"
}

budget agentOps {
  cpu    = "2 cores"
  memory = "4G"
}

runclass ephemeral {
  timeout = "60s"
  restart = "never"
}

ebpf networkPolicy {
  action = "deny"
  target = "egress"
}

observability agentTelemetry {
  backend = "otelcol"
  metrics = true
  traces  = true
}
