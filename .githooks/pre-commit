#!/bin/sh
which zig > /dev/null 2>&1 || exit 0
ZIG_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.zig$')
[ -z "$ZIG_FILES" ] && exit 0
HAS_ERRORS=0
for f in $ZIG_FILES; do
    [ -f "$f" ] || continue
    zig ast-check "$f" 2>&1
    if [ $? -ne 0 ]; then echo "❌ $f"; HAS_ERRORS=1; else echo "✅ $f"; fi
done
[ $HAS_ERRORS -ne 0 ] && echo "Fix Zig errors before commit." && exit 1
exit 0
