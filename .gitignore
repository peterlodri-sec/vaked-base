# --- Nix ---
result
result-*
.direnv/
.pre-commit-config.yaml.bak

# --- vakedc output (regenerable LPG: canonical JSON + SQLite) ---
.vaked/

# --- Python (vakedc prototype + tests/spec) ---
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Python editable-install artifacts
vakedc.egg-info/

# --- Zig (daemons + vakedz front-end) ---
zig-cache/
.zig-cache/
zig-out/
zig-*-linux-*/
zig-*-macos-*/
zig-*-windows-*/

# --- vakedz ralphloop-cache (regenerable: content-addressed CAS + hash-chained
#     ledger; rebuilt from sources on demand) ---
.vakedz-cache/

# --- BEAM / OTP (agent-supervisord) ---
_build/
deps/
*.beam
erl_crash.dump
.elixir_ls/

# --- Rust (CrabCC and friends, if vendored) ---
target/
Cargo.lock

# --- CrabCC indexes (regenerable; published as release artifacts) ---
.crabcc/
*.crabcc-index

# --- Editors / OS ---
.DS_Store
*.swp
.idea/
.vscode/

# --- Source bundles (contents are committed in-tree; keep the zip out of git) ---
*.zip

# --- Secrets — NEVER commit (Matrix token, env files) ---
.env
*.env
.matrix.env
secrets/

# --- Generated artifacts (spec dashboard) ---
tools/specdash/index.html

# Ralph state (per-model decision loop — append-only; reset on major rewrites)
# Intentionally NOT committed (local agent artifacts)
tools/ralph/state/status.json
tools/ralph/state/tracks.json

# Ralph development (venv, lock file)
# Intentionally NOT committed until Phase 4 (when langfuse integration lands)
tools/ralph/uv.lock
tools/ralph/.venv/

# Claude Code agent worktree scratch dirs (ephemeral isolation workspaces)
.claude/worktrees/

# Claude Code agent artifacts (ephemeral)
.claude/workflows/
.claude/ralph-loop.local.md

# Benchmark + docs validation cache (local agent artifacts)
.benchmark-results/
.docs-cache/

# Dogfood verification kernel runtime state (WAL, content-addressed blobs)
.dogfood/

.oracle/                # vaked-oracle runtime state (ledger, findings, cache)

# Go build artifacts (vaked-optitron) — the compiled binary; deps pinned via go.sum
tools/optitron/optitron

# Landing infrastructure cache (generated files, local agent artifacts)
.landing-cache/
docs/website/index.html
docs/website/examples.html
docs/website/docs.html

# Repowise codebase-graph cache (tool side-effect)
.repowise/

# DeepSeek / CodeWhale agent artifacts (ephemeral)
.deepseek/
.wrangler/
