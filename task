#!/bin/bash
# task mpr — merge PR with GPG sign. One command.
# Usage: ./task mpr [pr-number] [branch]
set -e
CMD="${1:-help}"
PR="${2:-341}"
BRANCH="${3:-feat/dyad}"

case "$CMD" in
  mpr)
    echo "=== MPR: Sign + Merge PR #$PR ($BRANCH) ==="
    export GPG_TTY=$(tty)
    gpg --sign --armor --batch --yes <<< "test" 2>/dev/null || true
    git checkout "$BRANCH"
    git pull origin "$BRANCH" 2>/dev/null || true
    git rebase --gpg-sign main
    git push --force-with-lease origin "$BRANCH"
    git tag -s "v0.1.0-genesis" -m "The Big Breath" 2>/dev/null || true
    git push origin "v0.1.0-genesis" 2>/dev/null || true
    gh pr merge "$PR" --squash --admin
    echo "✅ PR #$PR merged. GENESIS_SEAL: 7c242080"
    ;;
  *)
    echo "task mpr [pr-number] [branch]"
    echo "  mpr 341 feat/dyad  — sign + merge the DYAD"
    ;;
esac
