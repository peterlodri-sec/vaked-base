{
  "mcpServers": {
    "vaked-daemon": {
      "command": "curl",
      "args": ["-sf", "http://localhost:9090/health"],
      "description": "Vaked daemon health endpoint"
    },
    "vaked-memory": {
      "command": "python3",
      "args": ["-m", "agent_memoryd", "serve", "--host", "127.0.0.1", "--port", "8420"],
      "description": "Memory plane - store/recall/forget/verify"
    },
    "vaked-docs": {
      "command": "python3",
      "args": ["tools/mcp-servers/docs-mcp.py", "--port", "9845"],
      "description": "Vaked Docs index, no rate limits"
    },
    "vaked-rag": {
      "command": "python3",
      "args": ["tools/vaked-docs/rag_server.py", "--port", "9876"],
      "description": "Vaked RAG - semantic search across all docs"
    },
    "vaked-fleet": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_PERSONAL_TOKEN}" },
      "description": "GitHub MCP - issues, PRs, Actions"
    },
    "nix": {
      "command": "nix",
      "args": ["run", "github:utensils/mcp-nixos", "--"],
      "description": "MCP-NixOS: 130K+ packages, 23K+ options, home-manager, FlakeHub"
    }
  }
}
