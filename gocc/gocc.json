{
  "version": "0.1.0",
  "name": "gocc",
  "description": "Graph Orchestrated Code Command — Vaked-powered multi-agent orchestrator",
  "binary": "./zig-out/bin/gocc",
  "aliases": {
    "run": "gocc run",
    "build": "gocc build",
    "bench": "gocc bench",
    "verify": "gocc verify",
    "audit": "gocc verify --env",
    "patch": "gocc run workflows/patch.gocc",
    "sweep": "gocc run workflows/sweep.gocc",
    "bench-top": "gocc bench",
    "quarantine": "gocc run workflows/quarantine.gocc"
  },
  "hooks": {
    "preload_lib": {
      "macos": "./zig-out/lib/libgocc.dylib",
      "linux": "./zig-out/lib/libgocc.so"
    }
  },
  "defaults": {
    "parallel": 4,
    "nullclaw_socket_dir": "~/.nullclaw/sockets",
    "dragonfly_socket": "/tmp/dragonfly.sock",
    "zetabuf": ".gocc/state_transitions.log",
    "wave_timeout_ms": 30000
  }
}
